# Limitless API
LIMITLESS_API_KEY=your-limitless-api-key

# Postgres (Neon) - use the pooled connection string, postgresql+psycopg:// scheme
DATABASE_URL=postgresql+psycopg://user:password@host/dbname?sslmode=require

# Pinecone
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=limitless-lifelogs
PINECONE_NAMESPACE=default

# Neo4j Aura
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# LLM provider: OpenAI or any OpenAI-compatible API (synthesis + Graphiti extraction).
# For Theo (hitheo.ai) use the www host - the apex domain strips auth on redirect.
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://www.hitheo.ai/api/v1

# Models
CHAT_MODEL=gpt-4o
ROUTER_MODEL=gpt-4o-mini

# Privacy: PIN that unlocks owner mode (app starts locked in guest mode).
# Empty = always owner mode (no lock).
OWNER_PIN=
OWNER_SESSION_TIMEOUT_MINUTES=15

# Feature flags
ENABLE_GRAPH_INGESTION=false
